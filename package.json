{
  "name": "crowdsurf-v3",
  "version": "3.0.0",
  "description": "CrowdSurf — Windy-style surf forecast from locally-hosted GFS/ECMWF data",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "demo": "node data/scripts/generate-demo.js && node server.js",
    "download:gfs": "bash data/scripts/download-gfs.sh",
    "download:ecmwf": "bash data/scripts/download-ecmwf.sh",
    "process": "python3 data/scripts/process-grib.py",
    "update": "bash data/scripts/update.sh",
    "update:gfs": "bash data/scripts/update.sh gfs",
    "update:ecmwf": "bash data/scripts/update.sh ecmwf",
    "build:coast-points": "node data/scripts/build-coast-points.js",
    "fill:named-offshore": "node data/scripts/fill-named-offshore.js",
    "test:build": "node --test 'data/scripts/test/*.test.js'"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "kdbush": "^4.0.2"
  }
}
